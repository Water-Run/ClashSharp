<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.Triggers"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ClashSharp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="{StaticResource ClashPagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock x:Name="PageTitleText" Text="{Binding PageTitleText}" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock x:Name="DescriptionText" Text="{Binding DescriptionText}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid Grid.Row="1" Style="{StaticResource ClashCardGridStyle}" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="{Binding EnabledTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="{Binding EnabledDescriptionText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
            </StackPanel>

            <ToggleSwitch
                x:Name="TriggersEnabledSwitch"
                Grid.Column="1"
                MinWidth="0"
                IsOn="{Binding TriggersEnabled, Mode=TwoWay}"
                OnContent="{x:Null}"
                OffContent="{x:Null}"
                VerticalAlignment="Center" />

            <Button x:Name="AddTriggerButton" Grid.Column="2" Click="AddTriggerButton_Click" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="{Binding AddTriggerText}" />
                </StackPanel>
            </Button>

            <Button x:Name="OpenTriggerLogsButton" Grid.Column="3" Click="OpenTriggerLogsButton_Click" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8A5;" FontSize="14" />
                    <TextBlock Text="{Binding OpenTriggerLogsText}" />
                </StackPanel>
            </Button>
        </Grid>

        <ListView x:Name="TriggerTasksList" Grid.Row="2" ItemsSource="{Binding TriggerTasks}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Style="{StaticResource ClashCardGridStyle}" Margin="0,0,0,10" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon Glyph="&#xE7C1;" FontSize="20" Width="28" VerticalAlignment="Top" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <StackPanel Grid.Column="1" Spacing="8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding Name, Mode=TwoWay}" Tag="{Binding}" LostFocus="TriggerNameBox_LostFocus" />
                                <ToggleSwitch Grid.Column="1" IsOn="{Binding IsEnabled, Mode=TwoWay}" Tag="{Binding}" Toggled="TriggerEnabledToggle_Toggled" MinWidth="0" OnContent="{x:Null}" OffContent="{x:Null}" />
                            </Grid>

                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding ConditionsLabel}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding ConditionsSummary}" TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding ActionsLabel}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding ActionsSummary}" TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding LastTriggeredLabel}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding LastTriggeredSummary}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
                            <Button Tag="{Binding Id}" Click="MoveTriggerUpButton_Click">
                                <FontIcon Glyph="&#xE70E;" FontSize="14" />
                            </Button>
                            <Button Tag="{Binding Id}" Click="MoveTriggerDownButton_Click">
                                <FontIcon Glyph="&#xE70D;" FontSize="14" />
                            </Button>
                            <Button Tag="{Binding Id}" Click="DeleteTriggerButton_Click">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
