<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.Logs"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource ClashPagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="BackButton" Click="BackButton_Click">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <TextBlock x:Name="PageTitleText" Text="{Binding PageTitleText}" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="DescriptionText" Text="{Binding DescriptionText}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Grid Grid.Row="1" Style="{StaticResource ClashCardGridStyle}" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock x:Name="StorageTitleText" Text="{Binding StorageTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock x:Name="StorageUsageText" Text="{Binding StorageUsageText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <HyperlinkButton x:Name="CleanupButton" Grid.Column="1" Content="{Binding CleanupText}" Click="CleanupButton_Click" />
        </Grid>

        <Grid Grid.Row="2" Style="{StaticResource ClashCardGridStyle}" Margin="0,0,0,18" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="LogSearchBox"
                Header="{Binding SearchLabelText}"
                PlaceholderText="{Binding SearchPlaceholderText}"
                Text="{Binding SearchText, Mode=TwoWay}"
                TextChanged="LogSearchBox_TextChanged"
                VerticalAlignment="Bottom" />

            <ComboBox
                x:Name="LevelFilterBox"
                Grid.Column="1"
                Header="{Binding LevelFilterLabelText}"
                ItemsSource="{Binding LevelFilterOptions}"
                SelectedItem="{Binding SelectedLevelFilter, Mode=TwoWay}"
                SelectionChanged="FilterBox_SelectionChanged"
                HorizontalAlignment="Stretch" />

            <ComboBox
                x:Name="CategoryFilterBox"
                Grid.Column="2"
                Header="{Binding CategoryFilterLabelText}"
                ItemsSource="{Binding CategoryFilterOptions}"
                SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}"
                SelectionChanged="FilterBox_SelectionChanged"
                HorizontalAlignment="Stretch" />

            <Button x:Name="RefreshLogsButton" Grid.Column="3" Click="RefreshLogsButton_Click" VerticalAlignment="Bottom" ToolTipService.ToolTip="{Binding RefreshText}">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
        </Grid>

        <ListView x:Name="RecentLogsList" ItemsSource="{Binding RecentLogs}" Grid.Row="3">
            <ListView.Header>
                <Grid Padding="4,0,4,8" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding TimeColumnText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding LevelColumnText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="2" Text="{Binding CategoryColumnText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="3" Text="{Binding ContentColumnText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CreatedAtDisplay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding LevelDisplay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Grid.Column="2" Text="{Binding SourceDisplay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                        <StackPanel Grid.Column="3" Spacing="2">
                            <TextBlock Text="{Binding Message}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
