<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.MasterControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:ClashSharp.Components"
    xmlns:converters="using:ClashSharp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer
        x:Name="RootScrollViewer"
        Padding="24,18,24,24"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled"
        SizeChanged="RootScrollViewer_SizeChanged">
        <StackPanel x:Name="ContentHost" Spacing="14">
            <Grid x:Name="HeroAndModeGrid" ColumnSpacing="12" RowSpacing="10" MinHeight="342">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="380" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="HeroStatusCard" Grid.RowSpan="4" Style="{StaticResource ClashCardGridStyle}" Padding="18" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Image x:Name="HeaderLogo" Source="ms-appx:///Assets/Logo.png" Width="72" Height="72" Stretch="Uniform" HorizontalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Clash#" Style="{ThemeResource TitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{Binding BasicStatusText}" Style="{ThemeResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                        <HyperlinkButton
                            x:Name="SetHeroStatusDisplayButton"
                            Grid.Column="2"
                            Content="{Binding SetHeroStatusDisplayText}"
                            Padding="0"
                            VerticalAlignment="Top"
                            Click="SetHeroStatusDisplayButton_Click" />
                    </Grid>

                    <GridView
                        x:Name="HeroStatusItemGrid"
                        Grid.Row="1"
                        ItemsSource="{Binding HeroStatusItems}"
                        SelectionMode="None"
                        IsItemClickEnabled="False">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0,0,10,10" />
                                <Setter Property="MinWidth" Value="220" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="4" MinWidth="220">
                                    <TextBlock Text="{Binding Title}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Value}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Grid>

                <components:MasterModeButton
                    x:Name="DisabledModeButton"
                    Grid.Column="1"
                    Title="{Binding DisabledModeTitleText}"
                    Description="{Binding DisabledModeDescriptionText}"
                    Glyph="&#xE711;"
                    IsChecked="{Binding IsDisabledModeSelected, Mode=OneWay}"
                    Command="{Binding DisabledModeCommand}" />

                <components:MasterModeButton
                    x:Name="StandbyModeButton"
                    Grid.Row="1"
                    Grid.Column="1"
                    Title="{Binding StandbyModeTitleText}"
                    Description="{Binding StandbyModeDescriptionText}"
                    Glyph="&#xE774;"
                    IsChecked="{Binding IsStandbyModeSelected, Mode=OneWay}"
                    Command="{Binding StandbyModeCommand}" />

                <components:MasterModeButton
                    x:Name="RuleTakeoverModeButton"
                    Grid.Row="2"
                    Grid.Column="1"
                    Title="{Binding RuleTakeoverModeTitleText}"
                    Description="{Binding RuleTakeoverModeDescriptionText}"
                    Glyph="&#xE9D9;"
                    IsChecked="{Binding IsRuleTakeoverModeSelected, Mode=OneWay}"
                    Command="{Binding RuleTakeoverModeCommand}" />

                <components:MasterModeButton
                    x:Name="FullTakeoverModeButton"
                    Grid.Row="3"
                    Grid.Column="1"
                    Title="{Binding FullTakeoverModeTitleText}"
                    Description="{Binding FullTakeoverModeDescriptionText}"
                    Glyph="&#xE968;"
                    IsChecked="{Binding IsFullTakeoverModeSelected, Mode=OneWay}"
                    Command="{Binding FullTakeoverModeCommand}" />
            </Grid>

            <HyperlinkButton
                x:Name="EditInfoTilesLink"
                Content="{Binding EditInfoTilesText}"
                HorizontalAlignment="Left"
                Padding="0"
                Margin="8,0,0,0"
                Click="EditInfoTilesButton_Click" />

            <GridView
                    x:Name="InfoTileGrid"
                    Margin="0"
                    ItemsSource="{Binding VisibleInfoTiles}"
                    SelectionMode="None"
                    CanReorderItems="True"
                    CanDragItems="True"
                    AllowDrop="True"
                    IsItemClickEnabled="False"
                    SizeChanged="InfoTileGrid_SizeChanged"
                    ContainerContentChanging="InfoTileGrid_ContainerContentChanging">
                    <GridView.Transitions>
                        <TransitionCollection>
                            <ReorderThemeTransition />
                        </TransitionCollection>
                    </GridView.Transitions>
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="5,0,5,10" />
                            <Setter Property="MinWidth" Value="220" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <components:MasterInfoTile
                                Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Title="{Binding Title}"
                                Value="{Binding Value}"
                                Detail="{Binding Detail}"
                                Glyph="{Binding Glyph}"
                                IsToggleVisible="{Binding IsToggleVisible}"
                                IsToggleOn="{Binding IsToggleOn, Mode=TwoWay}"
                                TileCommand="{Binding TileCommand}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>
