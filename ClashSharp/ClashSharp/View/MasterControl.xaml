<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.MasterControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="18">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Source="ms-appx:///Assets/Logo.png" Width="44" Height="44" Stretch="Uniform" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock x:Name="PageTitleText" Style="{ThemeResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="DescriptionText" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="18" RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="主状态控件" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="选择 Clash# 如何接管 Windows 网络。透明代理开关位于设置。" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ToggleButton x:Name="DisabledModeButton" MinHeight="92" HorizontalContentAlignment="Stretch" IsChecked="True" Click="DisabledModeButton_Click">
                        <StackPanel Spacing="4" Padding="6">
                            <TextBlock Text="未启用" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="关闭核心并还原系统代理。" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ToggleButton>

                    <ToggleButton x:Name="StandbyModeButton" Grid.Column="1" MinHeight="92" HorizontalContentAlignment="Stretch" Click="StandbyModeButton_Click">
                        <StackPanel Spacing="4" Padding="6">
                            <TextBlock Text="待命" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="核心运行，默认直连。" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ToggleButton>

                    <ToggleButton x:Name="RuleTakeoverModeButton" Grid.Row="1" MinHeight="92" HorizontalContentAlignment="Stretch" Click="RuleTakeoverModeButton_Click">
                        <StackPanel Spacing="4" Padding="6">
                            <TextBlock Text="按规则接管" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="启动核心；规则策略接入待实现。" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ToggleButton>

                    <ToggleButton x:Name="FullTakeoverModeButton" Grid.Row="1" Grid.Column="1" MinHeight="92" HorizontalContentAlignment="Stretch" Click="FullTakeoverModeButton_Click">
                        <StackPanel Spacing="4" Padding="6">
                            <TextBlock Text="接管所有" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="启动核心；全局策略接入待实现。" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ToggleButton>
                </Grid>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="核心状态" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="CoreStatusText" Text="正在检查" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="系统代理" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="SystemProxyStatusText" Text="正在检查" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="透明代理" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="TransparentProxyStatusText" Text="按设置启用" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="核心配置" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="CoreConfigurationText" Text="正在检查" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
