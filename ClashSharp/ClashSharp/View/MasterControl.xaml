<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.MasterControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:ClashSharp.Components"
    xmlns:converters="using:ClashSharp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer
        Padding="24,18,24,24"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="360" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Grid Style="{StaticResource ClashCardGridStyle}" Padding="18" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Image x:Name="HeaderLogo" Source="ms-appx:///Assets/Square150x150Logo.scale-200.png" Width="72" Height="72" Stretch="Uniform" HorizontalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Clash#" Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock Text="{Binding BasicStatusText}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock x:Name="CoreStatusTitleText" Text="{Binding CoreStatusTitleText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="CoreStatusText" Text="{Binding CoreStatusText}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="SystemProxyTitleText" Text="{Binding SystemProxyTitleText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SystemProxyStatusText" Text="{Binding SystemProxyStatusText}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock x:Name="TransparentProxyTitleText" Text="{Binding TransparentProxyTitleText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="TransparentProxyStatusText" Text="{Binding TransparentProxyStatusText}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="4">
                            <TextBlock Text="{Binding CurrentNodeText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{Binding LatencySummaryText}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <Button x:Name="OpenLatencyDialogButton" Click="OpenLatencyDialogButton_Click" Padding="8,4">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1" RowSpacing="10" Margin="0,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <components:MasterModeButton
                        x:Name="DisabledModeButton"
                        Title="{Binding DisabledModeTitleText}"
                        Description="{Binding DisabledModeDescriptionText}"
                        Glyph="&#xE711;"
                        IsChecked="{Binding IsDisabledModeSelected, Mode=OneWay}"
                        Command="{Binding DisabledModeCommand}" />

                    <components:MasterModeButton
                        x:Name="StandbyModeButton"
                        Grid.Row="1"
                        Title="{Binding StandbyModeTitleText}"
                        Description="{Binding StandbyModeDescriptionText}"
                        Glyph="&#xE774;"
                        IsChecked="{Binding IsStandbyModeSelected, Mode=OneWay}"
                        Command="{Binding StandbyModeCommand}" />

                    <components:MasterModeButton
                        x:Name="RuleTakeoverModeButton"
                        Grid.Row="2"
                        Title="{Binding RuleTakeoverModeTitleText}"
                        Description="{Binding RuleTakeoverModeDescriptionText}"
                        Glyph="&#xE9D9;"
                        IsChecked="{Binding IsRuleTakeoverModeSelected, Mode=OneWay}"
                        Command="{Binding RuleTakeoverModeCommand}" />

                    <components:MasterModeButton
                        x:Name="FullTakeoverModeButton"
                        Grid.Row="3"
                        Title="{Binding FullTakeoverModeTitleText}"
                        Description="{Binding FullTakeoverModeDescriptionText}"
                        Glyph="&#xE968;"
                        IsChecked="{Binding IsFullTakeoverModeSelected, Mode=OneWay}"
                        Command="{Binding FullTakeoverModeCommand}" />
                </Grid>
            </Grid>

            <HyperlinkButton
                x:Name="EditInfoTilesLink"
                Content="{Binding EditInfoTilesText}"
                HorizontalAlignment="Left"
                Padding="0"
                Click="EditInfoTilesButton_Click" />

            <GridView
                    x:Name="InfoTileGrid"
                    Margin="0"
                    ItemsSource="{Binding InfoTiles}"
                    SelectionMode="None"
                    CanReorderItems="True"
                    AllowDrop="True"
                    IsItemClickEnabled="False"
                    SizeChanged="InfoTileGrid_SizeChanged"
                    ContainerContentChanging="InfoTileGrid_ContainerContentChanging">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="5,0,5,10" />
                            <Setter Property="MinWidth" Value="220" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <components:MasterInfoTile
                                Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Title="{Binding Title}"
                                Value="{Binding Value}"
                                Detail="{Binding Detail}"
                                Glyph="{Binding Glyph}"
                                IsToggleVisible="{Binding IsToggleVisible}"
                                IsToggleOn="{Binding IsToggleOn, Mode=TwoWay}"
                                TileCommand="{Binding TileCommand}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>
