<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.MasterControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        Padding="{StaticResource ClashPagePadding}"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="18">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Source="ms-appx:///Assets/Logo.png" Width="44" Height="44" Stretch="Uniform" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock x:Name="PageTitleText" Text="{Binding PageTitleText}" Style="{ThemeResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="DescriptionText" Text="{Binding DescriptionText}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <Grid Style="{StaticResource ClashCardGridStyle}" Padding="18" RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock x:Name="StatusControlTitleText" Text="{Binding StatusControlTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="StatusControlDescriptionText" Text="{Binding StatusControlDescriptionText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ToggleButton x:Name="DisabledModeButton" MinHeight="92" HorizontalContentAlignment="Stretch" IsChecked="{Binding IsDisabledModeSelected, Mode=OneWay}" Command="{Binding DisabledModeCommand}">
                        <Grid Padding="6" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE711;" FontSize="20" Width="28" VerticalAlignment="Top" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock x:Name="DisabledModeTitleText" Text="{Binding DisabledModeTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="DisabledModeDescriptionText" Text="{Binding DisabledModeDescriptionText}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </ToggleButton>

                    <ToggleButton x:Name="StandbyModeButton" Grid.Column="1" MinHeight="92" HorizontalContentAlignment="Stretch" IsChecked="{Binding IsStandbyModeSelected, Mode=OneWay}" Command="{Binding StandbyModeCommand}">
                        <Grid Padding="6" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE774;" FontSize="20" Width="28" VerticalAlignment="Top" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock x:Name="StandbyModeTitleText" Text="{Binding StandbyModeTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="StandbyModeDescriptionText" Text="{Binding StandbyModeDescriptionText}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </ToggleButton>

                    <ToggleButton x:Name="RuleTakeoverModeButton" Grid.Row="1" MinHeight="92" HorizontalContentAlignment="Stretch" IsChecked="{Binding IsRuleTakeoverModeSelected, Mode=OneWay}" Command="{Binding RuleTakeoverModeCommand}">
                        <Grid Padding="6" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE9D9;" FontSize="20" Width="28" VerticalAlignment="Top" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock x:Name="RuleTakeoverModeTitleText" Text="{Binding RuleTakeoverModeTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="RuleTakeoverModeDescriptionText" Text="{Binding RuleTakeoverModeDescriptionText}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </ToggleButton>

                    <ToggleButton x:Name="FullTakeoverModeButton" Grid.Row="1" Grid.Column="1" MinHeight="92" HorizontalContentAlignment="Stretch" IsChecked="{Binding IsFullTakeoverModeSelected, Mode=OneWay}" Command="{Binding FullTakeoverModeCommand}">
                        <Grid Padding="6" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE968;" FontSize="20" Width="28" VerticalAlignment="Top" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock x:Name="FullTakeoverModeTitleText" Text="{Binding FullTakeoverModeTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="FullTakeoverModeDescriptionText" Text="{Binding FullTakeoverModeDescriptionText}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </ToggleButton>
                </Grid>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Style="{StaticResource ClashCardGridStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="CoreStatusTitleText" Text="{Binding CoreStatusTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="CoreStatusText" Text="{Binding CoreStatusText}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1" Style="{StaticResource ClashCardGridStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="SystemProxyTitleText" Text="{Binding SystemProxyTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="SystemProxyStatusText" Text="{Binding SystemProxyStatusText}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="2" Style="{StaticResource ClashCardGridStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TransparentProxyTitleText" Text="{Binding TransparentProxyTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="TransparentProxyStatusText" Text="{Binding TransparentProxyStatusText}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
