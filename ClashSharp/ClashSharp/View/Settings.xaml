<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:ClashSharp.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        Padding="{StaticResource ClashPagePadding}"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitleText" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock x:Name="DescriptionText" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <TextBlock x:Name="LanguageSectionTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <components:SettingRow x:Name="LanguageRow">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="LanguageBox" MinWidth="180" SelectionChanged="LanguageBox_SelectionChanged">
                        <ComboBoxItem Content="简体中文" />
                        <ComboBoxItem Content="繁體中文" />
                        <ComboBoxItem Content="English" />
                        <ComboBoxItem Content="Русский" />
                        <ComboBoxItem Content="Français" />
                        <ComboBoxItem Content="Deutsch" />
                    </ComboBox>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="ProxySectionTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="TransparentProxyRow">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="TransparentProxyToggle" IsOn="False" OnContent="{x:Null}" OffContent="{x:Null}" Toggled="TransparentProxyToggle_Toggled" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="TunFallbackRow">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="TunFallbackToggle" IsOn="True" OnContent="{x:Null}" OffContent="{x:Null}" Toggled="TunFallbackToggle_Toggled" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="MixedPortRow">
                <components:SettingRow.ActionContent>
                    <NumberBox x:Name="MixedPortBox" Width="140" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Compact" ValueChanged="MixedPortBox_ValueChanged" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <Grid Style="{StaticResource ClashCardGridStyle}" MinHeight="96">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="ProxyInformationTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="ProxyInformationDescriptionText" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="ProxyLocalEntryText" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="ProxyCoreConfigurationText" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="ProxyCoreBinaryText" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Grid>

            <components:SettingRow x:Name="ConnectionSamplingRow">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="ConnectionSamplingToggle" OnContent="{x:Null}" OffContent="{x:Null}" Toggled="ConnectionSamplingToggle_Toggled" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="SamplingIntervalRow">
                <components:SettingRow.ActionContent>
                    <NumberBox x:Name="ConnectionSamplingIntervalBox" Width="140" Minimum="5" Maximum="3600" SpinButtonPlacementMode="Compact" ValueChanged="ConnectionSamplingIntervalBox_ValueChanged" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="WindowsNativeSectionTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <Grid Style="{StaticResource ClashCardGridStyle}" MinHeight="60">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="WindowsNativeTitleText" Style="{ThemeResource BodyTextBlockStyle}" />
                    <TextBlock x:Name="WindowsNativeDescriptionText" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <Grid Style="{StaticResource ClashCardGridStyle}" MinHeight="68">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="WslDiagnosticTitleText" Style="{ThemeResource BodyTextBlockStyle}" />
                    <TextBlock x:Name="WslDiagnosticStatusText" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button Grid.Column="1" Margin="12,0,0,0" Tag="Wsl:Diagnose" Click="WindowsDiagnosticButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                        <TextBlock x:Name="DiagnoseWslText" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Margin="8,0,0,0" Tag="Wsl:Apply" Click="WindowsDiagnosticButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE73E;" FontSize="14" />
                        <TextBlock x:Name="ApplyWslText" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Margin="8,0,0,0" Tag="Wsl:Reset" Click="WindowsDiagnosticButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock x:Name="ResetWslText" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Style="{StaticResource ClashCardGridStyle}" MinHeight="68">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="TerminalDiagnosticTitleText" Style="{ThemeResource BodyTextBlockStyle}" />
                    <TextBlock x:Name="TerminalDiagnosticStatusText" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button Grid.Column="1" Margin="12,0,0,0" Tag="Terminal:Diagnose" Click="WindowsDiagnosticButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE756;" FontSize="14" />
                        <TextBlock x:Name="DiagnoseTerminalText" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Margin="8,0,0,0" Tag="Terminal:Apply" Click="WindowsDiagnosticButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE73E;" FontSize="14" />
                        <TextBlock x:Name="ApplyTerminalText" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Margin="8,0,0,0" Tag="Terminal:Reset" Click="WindowsDiagnosticButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock x:Name="ResetTerminalText" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Style="{StaticResource ClashCardGridStyle}" MinHeight="68">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="StoreDiagnosticTitleText" Style="{ThemeResource BodyTextBlockStyle}" />
                    <TextBlock x:Name="StoreDiagnosticStatusText" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button Grid.Column="1" Margin="12,0,0,0" Tag="MicrosoftStore:Diagnose" Click="WindowsDiagnosticButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                        <TextBlock x:Name="DiagnoseStoreText" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Margin="8,0,0,0" Tag="MicrosoftStore:Apply" Click="WindowsDiagnosticButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE73E;" FontSize="14" />
                        <TextBlock x:Name="ApplyStoreText" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Margin="8,0,0,0" Tag="MicrosoftStore:Reset" Click="WindowsDiagnosticButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock x:Name="ResetStoreText" />
                    </StackPanel>
                </Button>
            </Grid>

            <components:SettingRow x:Name="CheckStaleProxyRow">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="CheckStaleProxyToggle" OnContent="{x:Null}" OffContent="{x:Null}" Toggled="CheckStaleProxyToggle_Toggled" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="RestoreProxyOnExitRow">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="RestoreProxyOnExitToggle" OnContent="{x:Null}" OffContent="{x:Null}" Toggled="RestoreProxyOnExitToggle_Toggled" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ProxyRecoveryModeRow">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="ProxyRecoveryModeBox" MinWidth="180" SelectionChanged="ProxyRecoveryModeBox_SelectionChanged">
                        <ComboBoxItem x:Name="ProxyRecoveryIgnoreItem" />
                        <ComboBoxItem x:Name="ProxyRecoveryEnableItem" />
                        <ComboBoxItem x:Name="ProxyRecoveryDisableItem" />
                    </ComboBox>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="MainlandChinaSectionTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="MainlandChinaDisplayRow">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="MainlandChinaFeatureModeBox" MinWidth="260" SelectionChanged="MainlandChinaFeatureModeBox_SelectionChanged">
                        <ComboBoxItem x:Name="MainlandChinaDisabledItem" />
                        <ComboBoxItem x:Name="MainlandChinaFlagOnlyItem" />
                        <ComboBoxItem x:Name="MainlandChinaFlagAndTextItem" />
                        <ComboBoxItem x:Name="MainlandChinaKeywordFilterItem" />
                        <ComboBoxItem x:Name="MainlandChinaAllItem" />
                    </ComboBox>
                </components:SettingRow.ActionContent>
            </components:SettingRow>
        </StackPanel>
    </ScrollViewer>
</Page>
