<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:ClashSharp.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        x:Name="SettingsScrollViewer"
        Padding="24,18,18,24"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="SettingsContentPanel" Spacing="6" HorizontalAlignment="Stretch">
            <TextBlock x:Name="LanguageSectionTitleText" Text="{Binding LanguageSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <components:SettingRow x:Name="LanguageRow" Title="{Binding LanguageTitleText}" Description="{Binding LanguageDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="LanguageBox" Width="180" ItemsSource="{Binding DisplayLanguageOptions}" SelectedIndex="{Binding DisplayLanguageIndex, Mode=TwoWay}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="AppThemeModeRow" Title="{Binding AppThemeModeTitleText}" Description="{Binding AppThemeModeDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="AppThemeModeBox" Width="180" ItemsSource="{Binding AppThemeModeOptions}" SelectedIndex="{Binding AppThemeModeIndex, Mode=TwoWay}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="AppAccentColorRow" Title="{Binding AppAccentColorTitleText}" Description="{Binding AppAccentColorDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ComboBox x:Name="AppAccentColorModeBox" Width="150" ItemsSource="{Binding AppAccentColorModeOptions}" SelectedIndex="{Binding AppAccentColorModeIndex, Mode=TwoWay}" />
                        <Button x:Name="AppAccentColorPickerButton" Width="40" MinWidth="40" Padding="0" Click="AppAccentColorPickerButton_Click" AutomationProperties.Name="{Binding AppAccentColorPickText}" ToolTipService.ToolTip="{Binding AppAccentColorPickText}">
                            <FontIcon Glyph="&#xE790;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="StartupSectionTitleText" Text="{Binding StartupSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="LaunchAtStartupRow" Title="{Binding LaunchAtStartupTitleText}" Description="{Binding LaunchAtStartupDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="LaunchAtStartupToggle" MinWidth="0" IsOn="{Binding LaunchAtStartupEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="CheckStartupConflictsRow" Title="{Binding CheckStartupConflictsTitleText}" Description="{Binding CheckStartupConflictsDescriptionText}">
                <components:SettingRow.ActionContent>
                    <Button x:Name="CheckStartupConflictsButton" Click="CheckStartupConflictsButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                            <TextBlock Text="{Binding CheckText}" />
                        </StackPanel>
                    </Button>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="StartupConflictCheckRow" Title="{Binding StartupConflictCheckTitleText}" Description="{Binding StartupConflictCheckDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="StartupConflictCheckToggle" MinWidth="0" IsOn="{Binding StartupConflictCheckEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ShowStartupGuideRow" Title="{Binding StartupGuideTitleText}" Description="{Binding StartupGuideDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="ShowStartupGuideToggle" MinWidth="0" IsOn="{Binding ShowStartupGuideOnStartup, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="StartupBehaviorModeRow" Title="{Binding StartupBehaviorModeTitleText}" Description="{Binding StartupBehaviorModeDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="StartupBehaviorModeBox" Width="180" ItemsSource="{Binding StartupBehaviorModeOptions}" SelectedIndex="{Binding StartupBehaviorModeIndex, Mode=TwoWay}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="TransparentProxySectionTitleText" Text="{Binding TransparentProxySectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="TransparentProxyRow" Title="{Binding TransparentProxyTitleText}" Description="{Binding TransparentProxyDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="TransparentProxyToggle" MinWidth="0" IsOn="{Binding TransparentProxyEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="TransparentProxyServiceRow" Title="{Binding TransparentProxyServiceTitleText}" Description="{Binding TransparentProxyServiceDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MihomoServiceStatusText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextWrapping="NoWrap" />
                        <Button x:Name="DeployMihomoServiceButton" Command="{Binding DeployMihomoServiceCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE898;" FontSize="14" />
                                <TextBlock Text="{Binding DeployMihomoServiceText}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="UninstallMihomoServiceButton" Command="{Binding UninstallMihomoServiceCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock Text="{Binding UninstallMihomoServiceText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="ProxySectionTitleText" Text="{Binding ProxySectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="MixedPortRow" Title="{Binding MixedPortTitleText}" Description="{Binding MixedPortDescriptionText}">
                <components:SettingRow.ActionContent>
                    <NumberBox x:Name="MixedPortBox" Width="140" Minimum="1" Maximum="65535" Value="{Binding MixedPortValue, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ConnectionTestUrlRow" Title="{Binding ConnectionTestUrlTitleText}" Description="{Binding ConnectionTestUrlDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="ConnectionTestUrlBox" Width="260" Text="{Binding ConnectionTestUrl, Mode=OneWay}" LostFocus="ConnectionTestUrlBox_LostFocus" />
                        <Button x:Name="ConnectionTestButton" Click="ConnectionTestButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                                <TextBlock Text="{Binding TestText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ConnectionSamplingRow" Title="{Binding ConnectionSamplingTitleText}" Description="{Binding ConnectionSamplingDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="ConnectionSamplingToggle" MinWidth="0" IsOn="{Binding ConnectionSamplingEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="SamplingIntervalRow" Title="{Binding SamplingIntervalTitleText}" Description="{Binding SamplingIntervalDescriptionText}">
                <components:SettingRow.ActionContent>
                    <NumberBox x:Name="ConnectionSamplingIntervalBox" Width="140" Minimum="5" Maximum="3600" Value="{Binding ConnectionSamplingIntervalSecondsValue, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="WindowsNativeSectionTitleText" Text="{Binding WindowsNativeSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <Grid Style="{StaticResource ClashCardGridStyle}" MinHeight="60">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock x:Name="WindowsNativeTitleText" Text="{Binding WindowsNativeTitleText}" Style="{ThemeResource BodyTextBlockStyle}" />
                    <TextBlock x:Name="WindowsNativeDescriptionText" Text="{Binding WindowsNativeDescriptionText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Click="OpenNetworkRepairButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                        <TextBlock x:Name="OpenNetworkRepairText" Text="{Binding OpenText}" />
                    </StackPanel>
                </Button>
            </Grid>

            <components:SettingRow x:Name="CheckStaleProxyRow" Title="{Binding CheckStaleProxyTitleText}" Description="{Binding CheckStaleProxyDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="CheckStaleProxyToggle" MinWidth="0" IsOn="{Binding CheckStaleProxyOnStartup, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="RestoreProxyOnExitRow" Title="{Binding RestoreProxyOnExitTitleText}" Description="{Binding RestoreProxyOnExitDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="RestoreProxyOnExitToggle" MinWidth="0" IsOn="{Binding RestoreProxyOnExit, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ProxyRecoveryModeRow" Title="{Binding ProxyRecoveryModeTitleText}" Description="{Binding ProxyRecoveryModeDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="ProxyRecoveryModeBox" Width="180" ItemsSource="{Binding ProxyRecoveryModeOptions}" SelectedIndex="{Binding ProxyRecoveryModeIndex, Mode=TwoWay}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="MainlandChinaSectionTitleText" Text="{Binding MainlandChinaSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="MainlandChinaDisplayRow" Title="{Binding MainlandChinaDisplayTitleText}" Description="{Binding MainlandChinaDisplayDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="MainlandChinaFeatureModeBox" Width="280" ItemsSource="{Binding MainlandChinaFeatureModeOptions}" SelectedIndex="{Binding MainlandChinaFeatureModeIndex, Mode=TwoWay}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="MainlandChinaUrlBlockingRow" Title="{Binding MainlandChinaUrlBlockingTitleText}" Description="{Binding MainlandChinaUrlBlockingDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="MainlandChinaUrlBlockingToggle" MinWidth="0" IsOn="{Binding MainlandChinaUrlBlockingEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="DataSectionTitleText" Text="{Binding DataSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="ResetAllSettingsRow" Title="{Binding ResetAllSettingsTitleText}" Description="{Binding ResetAllSettingsDescriptionText}">
                <components:SettingRow.ActionContent>
                    <HyperlinkButton x:Name="ResetAllSettingsLink" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" Content="{Binding ResetText}" Click="ResetAllSettingsButton_Click" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ClearAllDataRow" Title="{Binding ClearAllDataTitleText}" Description="{Binding ClearAllDataDescriptionText}">
                <components:SettingRow.ActionContent>
                    <HyperlinkButton x:Name="ClearAllDataLink" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" Content="{Binding CleanupText}" Click="ClearAllDataButton_Click" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>
        </StackPanel>
    </ScrollViewer>
</Page>
