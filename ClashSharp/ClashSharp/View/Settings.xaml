<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:ClashSharp.Components"
    xmlns:converters="using:ClashSharp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:HexColorBrushConverter x:Key="HexColorBrushConverter" />
    </Page.Resources>

    <ScrollViewer
        x:Name="SettingsScrollViewer"
        Padding="24,18,18,24"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="SettingsContentPanel" Spacing="6" HorizontalAlignment="Stretch">
            <TextBlock
                x:Name="SettingsRestartRequiredNoticeText"
                Text="{Binding RestartRequiredNoticeText}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                FontWeight="SemiBold"
                HorizontalAlignment="Right"
                TextWrapping="Wrap"
                Visibility="{Binding HasRestartRequiredSettings, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <TextBlock x:Name="LanguageSectionTitleText" Text="{Binding LanguageSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <components:SettingRow x:Name="LanguageRow" Title="{Binding LanguageTitleText}" Description="{Binding LanguageDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="LanguageBox" Width="180" ItemsSource="{Binding DisplayLanguageOptions}" SelectedIndex="{Binding DisplayLanguageIndex, Mode=TwoWay}" SelectionChanged="LanguageBox_SelectionChanged" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="AppThemeModeRow" Title="{Binding AppThemeModeTitleText}" Description="{Binding AppThemeModeDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="AppThemeModeBox" Width="180" ItemsSource="{Binding AppThemeModeOptions}" SelectedIndex="{Binding AppThemeModeIndex, Mode=TwoWay}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="AppAccentColorRow" Title="{Binding AppAccentColorTitleText}" Description="{Binding AppAccentColorDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ComboBox x:Name="AppAccentColorModeBox" Width="150" ItemsSource="{Binding AppAccentColorModeOptions}" SelectedIndex="{Binding AppAccentColorModeIndex, Mode=TwoWay}" SelectionChanged="AppAccentColorModeBox_SelectionChanged" />
                        <Button
                            x:Name="AppAccentColorSwatchButton"
                            Width="32"
                            Height="32"
                            MinWidth="32"
                            Padding="4"
                            Click="AppAccentColorSwatchButton_Click"
                            AutomationProperties.Name="{Binding AppAccentColorPickText}"
                            ToolTipService.ToolTip="{Binding AppAccentColorPickText}"
                            Visibility="{Binding IsCustomAccentColorSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border
                                Width="20"
                                Height="20"
                                CornerRadius="4"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                Background="{Binding AppAccentColorValue, Converter={StaticResource HexColorBrushConverter}}" />
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="CloseBehaviorModeRow" Title="{Binding CloseBehaviorModeTitleText}" Description="{Binding CloseBehaviorModeDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="CloseBehaviorModeBox" Width="220" ItemsSource="{Binding CloseBehaviorModeOptions}" SelectedIndex="{Binding CloseBehaviorModeIndex, Mode=TwoWay}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <HyperlinkButton x:Name="ResetBasicSettingsLink" Content="{Binding ResetGroupToDefaultsText}" HorizontalAlignment="Right" Margin="0,0,8,0" Padding="0" Click="ResetBasicSettingsButton_Click" />

            <TextBlock x:Name="StartupSectionTitleText" Text="{Binding StartupSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="LaunchAtStartupRow" Title="{Binding LaunchAtStartupTitleText}" Description="{Binding LaunchAtStartupDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="LaunchAtStartupToggle" MinWidth="0" IsOn="{Binding LaunchAtStartupEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="StartupConflictCheckRow" Title="{Binding StartupConflictCheckTitleText}" Description="{Binding StartupConflictCheckDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ToggleSwitch x:Name="StartupConflictCheckToggle" MinWidth="0" IsOn="{Binding StartupConflictCheckEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                        <Button x:Name="CheckStartupConflictsButton" Click="CheckStartupConflictsButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                                <TextBlock Text="{Binding CheckStartupConflictsNowText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ShowStartupGuideRow" Title="{Binding StartupGuideTitleText}" Description="{Binding StartupGuideDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ToggleSwitch x:Name="ShowStartupGuideToggle" MinWidth="0" IsOn="{Binding ShowStartupGuideOnStartup, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                        <Button x:Name="ShowStartupPromptButton" Click="ShowStartupPromptButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE946;" FontSize="14" />
                                <TextBlock Text="{Binding StartupGuideShowNowText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="StartupBehaviorModeRow" Title="{Binding StartupBehaviorModeTitleText}" Description="{Binding StartupBehaviorModeDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="StartupBehaviorModeBox" Width="180" ItemsSource="{Binding StartupBehaviorModeOptions}" SelectedIndex="{Binding StartupBehaviorModeIndex, Mode=TwoWay}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>
            <HyperlinkButton x:Name="ResetStartupSettingsLink" Content="{Binding ResetGroupToDefaultsText}" HorizontalAlignment="Right" Margin="0,0,8,0" Padding="0" Click="ResetStartupSettingsButton_Click" />

            <TextBlock x:Name="ProxySectionTitleText" Text="{Binding ProxySectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="TransparentProxyRow" Title="{Binding TransparentProxyTitleText}" Description="{Binding TransparentProxyDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="TransparentProxyToggle" MinWidth="0" IsEnabled="{Binding CanToggleTransparentProxy}" IsOn="{Binding TransparentProxyEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="TransparentProxyServiceRow" Title="{Binding TransparentProxyServiceTitleText}" Description="{Binding TransparentProxyServiceDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock x:Name="MihomoServiceStatusText" Text="{Binding MihomoServiceStatusText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxWidth="160" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        <Button x:Name="DeployMihomoServiceButton" Command="{Binding DeployMihomoServiceCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE898;" FontSize="14" />
                                <TextBlock Text="{Binding DeployMihomoServiceText}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="UninstallMihomoServiceButton" Command="{Binding UninstallMihomoServiceCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock Text="{Binding UninstallMihomoServiceText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="MixedPortRow" Title="{Binding MixedPortTitleText}" Description="{Binding MixedPortDescriptionText}">
                <components:SettingRow.ActionContent>
                    <NumberBox x:Name="MixedPortBox" Width="140" Minimum="1" Maximum="65535" Value="{Binding MixedPortValue, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ConnectionTestUrlRow" Title="{Binding ConnectionTestUrlTitleText}" Description="{Binding ConnectionTestUrlDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding ConnectionTestUrlSummaryText}" Width="260" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Button x:Name="EditConnectionTestUrlsButton" Click="EditConnectionTestUrlsButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE70F;" FontSize="14" />
                                <TextBlock Text="{Binding EditText}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ConnectionTestButton" Click="ConnectionTestButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                                <TextBlock Text="{Binding TestText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ConnectionSamplingRow" Title="{Binding ConnectionSamplingTitleText}" Description="{Binding ConnectionSamplingDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="ConnectionSamplingToggle" MinWidth="0" IsOn="{Binding ConnectionSamplingEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="SamplingIntervalRow" Title="{Binding SamplingIntervalTitleText}" Description="{Binding SamplingIntervalDescriptionText}">
                <components:SettingRow.ActionContent>
                    <NumberBox x:Name="ConnectionSamplingIntervalBox" Width="140" Minimum="3" Maximum="300" Value="{Binding ConnectionSamplingIntervalSecondsValue, Mode=TwoWay}" SpinButtonPlacementMode="Compact" ValidationMode="InvalidInputOverwritten" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>
            <HyperlinkButton x:Name="ResetProxySettingsLink" Content="{Binding ResetGroupToDefaultsText}" HorizontalAlignment="Right" Margin="0,0,8,0" Padding="0" Click="ResetProxySettingsButton_Click" />

            <TextBlock x:Name="WindowsNativeSectionTitleText" Text="{Binding WindowsNativeSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="StartupRestoreFallbackRow" Title="{Binding StartupRestoreFallbackTitleText}" Description="{Binding StartupRestoreFallbackDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock x:Name="StartupRestoreFallbackStatusText" Text="{Binding StartupRestoreFallbackStatusText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxWidth="160" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        <Button x:Name="RegisterStartupRestoreFallbackButton" Click="RegisterStartupRestoreFallbackButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8FB;" FontSize="14" />
                                <TextBlock Text="{Binding RegisterText}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DetectStartupRestoreFallbackButton" Click="DetectStartupRestoreFallbackButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                                <TextBlock Text="{Binding DetectText}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="UninstallStartupRestoreFallbackButton" Click="UninstallStartupRestoreFallbackButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock Text="{Binding UninstallMihomoServiceText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <Grid x:Name="WindowsNativeRepairCard" Style="{StaticResource ClashCardGridStyle}" MinHeight="60">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock x:Name="WindowsNativeTitleText" Text="{Binding WindowsNativeTitleText}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock x:Name="WindowsNativeDescriptionText" Text="{Binding WindowsNativeDescriptionText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Click="OpenNetworkRepairButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                        <TextBlock x:Name="OpenNetworkRepairText" Text="{Binding OpenText}" />
                    </StackPanel>
                </Button>
            </Grid>

            <components:SettingRow x:Name="CheckStaleProxyRow" Title="{Binding CheckStaleProxyTitleText}" Description="{Binding CheckStaleProxyDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="CheckStaleProxyToggle" MinWidth="0" IsOn="{Binding CheckStaleProxyOnStartup, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="RestoreProxyOnExitRow" Title="{Binding RestoreProxyOnExitTitleText}" Description="{Binding RestoreProxyOnExitDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="RestoreProxyOnExitToggle" MinWidth="0" IsOn="{Binding RestoreProxyOnExit, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <HyperlinkButton x:Name="ResetWindowsNativeSettingsLink" Content="{Binding ResetGroupToDefaultsText}" HorizontalAlignment="Right" Margin="0,0,8,0" Padding="0" Click="ResetWindowsNativeSettingsButton_Click" />

            <TextBlock x:Name="NotificationSectionTitleText" Text="{Binding NotificationSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="NotificationEnabledRow" Title="{Binding NotificationEnabledTitleText}" Description="{Binding NotificationEnabledDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="NotificationEnabledToggle" MinWidth="0" IsOn="{Binding NotificationEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="NotificationLevelRow" Title="{Binding NotificationTitleText}" Description="{Binding NotificationDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="NotificationLevelBox" Width="180" ItemsSource="{Binding NotificationLevelOptions}" SelectedIndex="{Binding NotificationLevelIndex, Mode=TwoWay}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>
            <HyperlinkButton x:Name="ResetNotificationSettingsLink" Content="{Binding ResetGroupToDefaultsText}" HorizontalAlignment="Right" Margin="0,0,8,0" Padding="0" Click="ResetNotificationSettingsButton_Click" />

            <TextBlock x:Name="TriggerSectionTitleText" Text="{Binding TriggerSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="TriggersEnabledRow" Title="{Binding TriggersEnabledTitleText}" Description="{Binding TriggersEnabledDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="TriggersEnabledToggle" MinWidth="0" IsOn="{Binding TriggersEnabled, Mode=OneWay}" OnContent="{x:Null}" OffContent="{x:Null}" Toggled="TriggersEnabledToggle_Toggled" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="TriggerNotificationsEnabledRow" Title="{Binding TriggerNotificationsEnabledTitleText}" Description="{Binding TriggerNotificationsEnabledDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="TriggerNotificationsEnabledToggle" MinWidth="0" IsOn="{Binding TriggerNotificationsEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>
            <HyperlinkButton x:Name="ResetTriggerSettingsLink" Content="{Binding ResetGroupToDefaultsText}" HorizontalAlignment="Right" Margin="0,0,8,0" Padding="0" Click="ResetTriggerSettingsButton_Click" />

            <TextBlock x:Name="TraySectionTitleText" Text="{Binding TraySectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="TrayUseMonochromeInactiveIconRow" Title="{Binding TrayUseMonochromeInactiveIconTitleText}" Description="{Binding TrayUseMonochromeInactiveIconDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="TrayUseMonochromeInactiveIconToggle" MinWidth="0" IsOn="{Binding TrayUseMonochromeInactiveIcon, Mode=OneWay}" OnContent="{x:Null}" OffContent="{x:Null}" Toggled="TrayUseMonochromeInactiveIconToggle_Toggled" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="TrayVisibleFeaturesRow" Title="{Binding TrayVisibleFeaturesTitleText}" Description="{Binding TrayVisibleFeaturesDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding TrayVisibleFeatureSummaryText}" MinWidth="120" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Button x:Name="EditTrayVisibleFeaturesButton" Click="EditTrayVisibleFeaturesButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE70F;" FontSize="14" />
                                <TextBlock Text="{Binding EditText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>
            <HyperlinkButton x:Name="ResetTraySettingsLink" Content="{Binding ResetGroupToDefaultsText}" HorizontalAlignment="Right" Margin="0,0,8,0" Padding="0" Click="ResetTraySettingsButton_Click" />

            <TextBlock x:Name="MainlandChinaSectionTitleText" Text="{Binding MainlandChinaSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="MainlandChinaDisplayRow" Title="{Binding MainlandChinaDisplayTitleText}" Description="{Binding MainlandChinaDisplayDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="MainlandChinaFeatureModeBox" Width="280" ItemsSource="{Binding MainlandChinaFeatureModeOptions}" SelectedIndex="{Binding MainlandChinaFeatureModeIndex, Mode=TwoWay}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="MainlandChinaUrlBlockingRow" Title="{Binding MainlandChinaUrlBlockingTitleText}" Description="{Binding MainlandChinaUrlBlockingDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ToggleSwitch x:Name="MainlandChinaUrlBlockingToggle" MinWidth="0" IsOn="{Binding MainlandChinaUrlBlockingEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>
            <HyperlinkButton x:Name="ResetMainlandChinaSettingsLink" Content="{Binding ResetGroupToDefaultsText}" HorizontalAlignment="Right" Margin="0,0,8,0" Padding="0" Click="ResetMainlandChinaSettingsButton_Click" />

            <TextBlock x:Name="DataSectionTitleText" Text="{Binding DataSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="DataPackageRow" Title="{Binding BackupRestoreTitleText}" Description="{Binding BackupRestoreDescriptionText}">
                <components:SettingRow.ActionContent>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="ExportDataPackageButton" Click="ExportDataPackageButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74E;" FontSize="14" />
                                <TextBlock Text="{Binding ExportText}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ImportDataPackageButton" Click="ImportDataPackageButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8B5;" FontSize="14" />
                                <TextBlock Text="{Binding ImportText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ResetAllSettingsRow" Title="{Binding ResetAllSettingsTitleText}" Description="{Binding ResetAllSettingsDescriptionText}">
                <components:SettingRow.ActionContent>
                    <HyperlinkButton x:Name="ResetAllSettingsLink" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" Content="{Binding ResetText}" Click="ResetAllSettingsButton_Click" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ClearAllDataRow" Title="{Binding ClearAllDataTitleText}" Description="{Binding ClearAllDataDescriptionText}">
                <components:SettingRow.ActionContent>
                    <HyperlinkButton x:Name="ClearAllDataLink" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" Content="{Binding CleanupText}" Click="ClearAllDataButton_Click" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>
        </StackPanel>
    </ScrollViewer>
</Page>
