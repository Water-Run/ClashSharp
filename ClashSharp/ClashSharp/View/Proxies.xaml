<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.Proxies"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource ClashPagePadding}">
        <StackPanel Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitleText" Text="{Binding PageTitleText}" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock x:Name="DescriptionText" Text="{Binding DescriptionText}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <CommandBar DefaultLabelPosition="Right" Background="Transparent">
                <AppBarButton x:Name="RefreshNodesButton" Label="{Binding RefreshNodesText}" Command="{Binding RefreshNodesCommand}">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE72C;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="TestLatencyButton" Label="{Binding TestLatencyText}" Command="{Binding TestLatencyCommand}">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="RefreshRuntimeButton" Label="{Binding RefreshRuntimeText}" Command="{Binding RefreshRuntimeCommand}">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE895;" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>

            <TextBlock x:Name="RuntimeStatusText" Text="{Binding RuntimeStatusText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <TextBlock x:Name="ProxyGroupsSectionTitleText" Text="{Binding ProxyGroupsSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <ListView x:Name="ProxyGroupsList" ItemsSource="{Binding ProxyGroups}" MaxHeight="220">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding NameDisplay}" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding Type}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox
                                Grid.Column="2"
                                MinWidth="220"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding Candidates}"
                                SelectedItem="{Binding CurrentSelection, Mode=OneWay}"
                                SelectionChanged="ProxyGroupSelectionChanged" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ListView x:Name="ProxyNodesList" ItemsSource="{Binding ProxyNodes}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Border Width="28" Height="20" CornerRadius="2" Background="{ThemeResource ControlFillColorDefaultBrush}">
                                    <Image Source="{Binding Region.FlagAssetPath}" Stretch="UniformToFill" />
                                </Border>
                                <TextBlock Text="{Binding Region.DisplayName}" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding NameDisplay}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock Grid.Column="2" Text="{Binding Protocol}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Column="3" Text="{Binding LatencyMilliseconds}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock x:Name="ProviderResourcesSectionTitleText" Text="{Binding ProviderResourcesSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <ListView x:Name="ProviderResourcesList" ItemsSource="{Binding ProviderResources}" MaxHeight="220">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding NameDisplay}" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding TypeDisplay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding DetailDisplay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding ItemCountDisplay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding UpdatedAtDisplay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <Button
                                Grid.Column="5"
                                Padding="8,4"
                                Command="{Binding DataContext.UpdateProviderCommand, ElementName=ProviderResourcesList}"
                                CommandParameter="{Binding}">
                                <FontIcon Glyph="&#xE895;" FontSize="14" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
