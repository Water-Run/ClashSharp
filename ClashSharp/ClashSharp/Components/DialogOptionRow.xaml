<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ClashSharp.Components.DialogOptionRow"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Button
        x:Name="OptionButton"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        Padding="0"
        Background="Transparent"
        BorderThickness="0"
        Click="OptionButton_Click">
        <Grid
            Style="{StaticResource ClashCardGridStyle}"
            MinHeight="72"
            Padding="10,8"
            ColumnSpacing="10"
            HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <CheckBox
                x:Name="SelectionCheckBox"
                Grid.Column="0"
                Width="32"
                MinWidth="0"
                Padding="0"
                IsChecked="{Binding IsChecked, ElementName=Root, Mode=TwoWay}"
                IsHitTestVisible="False"
                VerticalAlignment="Center" />

            <FontIcon
                Grid.Column="1"
                Glyph="{Binding Glyph, ElementName=Root}"
                FontSize="18"
                Width="24"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <Grid Grid.Column="2" RowSpacing="3" MinWidth="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8" MinWidth="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Text="{Binding Title, ElementName=Root}"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        MinWidth="0"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding Metadata, ElementName=Root}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center"
                        MaxWidth="160"
                        TextTrimming="CharacterEllipsis" />
                </Grid>

                <TextBlock
                    Grid.Row="1"
                    Text="{Binding Description, ElementName=Root}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="WrapWholeWords"
                    MaxLines="2"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </Grid>
    </Button>
</UserControl>
