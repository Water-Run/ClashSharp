<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ClashSharp.Components.DialogOptionRow"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ClashSharp.Converters">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <ToggleButton
        x:Name="OptionButton"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        Padding="0"
        IsChecked="{Binding IsChecked, ElementName=Root, Mode=TwoWay}"
        Click="OptionButton_Click">
        <Grid MinHeight="64" Padding="10,8" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon
                Glyph="{Binding Glyph, ElementName=Root}"
                FontSize="18"
                Width="24"
                VerticalAlignment="Top"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <StackPanel Grid.Column="1" Spacing="3" MinWidth="0">
                <Grid x:Name="DialogOptionHeadingGrid" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Text="{Binding Title, ElementName=Root}"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding Metadata, ElementName=Root}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center"
                        MaxWidth="180"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
                <TextBlock
                    Text="{Binding Description, ElementName=Root}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="WrapWholeWords"
                    MaxLines="2"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <FontIcon
                x:Name="SelectedGlyph"
                Grid.Column="2"
                Glyph="&#xE73E;"
                FontSize="16"
                Width="24"
                VerticalAlignment="Center"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                Visibility="{Binding IsChecked, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Grid>
    </ToggleButton>
</UserControl>
