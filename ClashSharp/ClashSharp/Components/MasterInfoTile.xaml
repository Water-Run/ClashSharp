<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ClashSharp.Components.MasterInfoTile"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ClashSharp.Converters">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid
        x:Name="TileRoot"
        Style="{StaticResource ClashCardGridStyle}"
        MinHeight="116"
        RowSpacing="10"
        Tapped="TileRoot_Tapped">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="SwitchStates">
                <VisualState x:Name="SwitchOff">
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="SelectedOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                        <DoubleAnimation Storyboard.TargetName="ToggleThumbTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.16" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="SwitchOn">
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="SelectedOverlay" Storyboard.TargetProperty="Opacity" To="0.14" Duration="0:0:0.18" />
                        <DoubleAnimation Storyboard.TargetName="ToggleThumbTransform" Storyboard.TargetProperty="X" To="16" Duration="0:0:0.18" />
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="SelectedOverlay"
            Grid.RowSpan="2"
            Margin="-16"
            CornerRadius="4"
            Background="{ThemeResource AccentFillColorDefaultBrush}"
            Opacity="0" />

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon
                Glyph="{Binding Glyph, ElementName=Root}"
                FontSize="18"
                Width="24"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
                Grid.Column="1"
                Text="{Binding Title, ElementName=Root}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextTrimming="CharacterEllipsis" />
            <Border
                x:Name="SwitchTrack"
                Grid.Column="2"
                Width="36"
                Height="20"
                CornerRadius="10"
                Background="{ThemeResource ControlFillColorTertiaryBrush}"
                Visibility="{Binding IsToggleVisible, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border
                    Width="16"
                    Height="16"
                    Margin="2"
                    HorizontalAlignment="Left"
                    CornerRadius="8"
                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ToggleThumbTransform" />
                    </Border.RenderTransform>
                </Border>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" Spacing="4" VerticalAlignment="Bottom">
            <TextBlock
                Text="{Binding Value, ElementName=Root}"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                TextWrapping="WrapWholeWords"
                MaxLines="2"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                Text="{Binding Detail, ElementName=Root}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="WrapWholeWords"
                MaxLines="2"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</UserControl>
