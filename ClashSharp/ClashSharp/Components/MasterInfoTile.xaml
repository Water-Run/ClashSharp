<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ClashSharp.Components.MasterInfoTile"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ClashSharp.Converters">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid
        x:Name="TileRoot"
        Style="{StaticResource ClashCardGridStyle}"
        MinHeight="116"
        RowSpacing="10"
        Tapped="TileRoot_Tapped">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="SelectedOverlay"
            Grid.RowSpan="2"
            Margin="-16"
            CornerRadius="4"
            Background="{ThemeResource AccentFillColorDefaultBrush}"
            Opacity="0.14"
            Visibility="{Binding IsToggleOn, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <FontIcon
                Glyph="{Binding Glyph, ElementName=Root}"
                FontSize="18"
                Width="24"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
                Grid.Column="1"
                Text="{Binding Title, ElementName=Root}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextTrimming="CharacterEllipsis" />
        </Grid>

        <StackPanel Grid.Row="1" Spacing="4" VerticalAlignment="Bottom">
            <TextBlock
                Text="{Binding Value, ElementName=Root}"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                TextWrapping="WrapWholeWords"
                MaxLines="2"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                Text="{Binding Detail, ElementName=Root}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="WrapWholeWords"
                MaxLines="2"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</UserControl>
