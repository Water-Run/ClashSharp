<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ClashSharp.Components.MasterModeButton"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ClashSharp.Converters">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Button
        x:Name="ModeButton"
        MinHeight="78"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        Padding="0"
        Background="Transparent"
        BorderThickness="0"
        Command="{Binding Command, ElementName=Root}">
        <Grid Style="{StaticResource ClashCardGridStyle}" Padding="12" ColumnSpacing="10" MinHeight="78">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="SelectedOverlay"
                Grid.ColumnSpan="2"
                Margin="-12"
                CornerRadius="4"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                Opacity="0.16"
                Visibility="{Binding IsChecked, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <FontIcon
                Glyph="{Binding Glyph, ElementName=Root}"
                FontSize="20"
                Width="28"
                VerticalAlignment="Top"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

            <StackPanel Grid.Column="1" Spacing="3">
                <TextBlock
                    Text="{Binding Title, ElementName=Root}"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock
                    Text="{Binding Description, ElementName=Root}"
                    TextWrapping="WrapWholeWords"
                    MaxLines="2"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Opacity="0.78"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </Button>
</UserControl>
