<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ClashSharp.Components.MasterModeButton"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <RadioButton
        x:Name="ModeRadioButton"
        GroupName="MasterControlMode"
        MinHeight="78"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        IsChecked="{Binding IsChecked, ElementName=Root, Mode=OneWay}"
        Command="{Binding Command, ElementName=Root}">
        <Grid Style="{StaticResource ClashCardGridStyle}" Padding="12" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <FontIcon
                Glyph="{Binding Glyph, ElementName=Root}"
                FontSize="20"
                Width="28"
                VerticalAlignment="Top"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

            <StackPanel Grid.Column="1" Spacing="3">
                <TextBlock
                    Text="{Binding Title, ElementName=Root}"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock
                    Text="{Binding Description, ElementName=Root}"
                    TextWrapping="WrapWholeWords"
                    MaxLines="2"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Opacity="0.78"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </RadioButton>
</UserControl>
