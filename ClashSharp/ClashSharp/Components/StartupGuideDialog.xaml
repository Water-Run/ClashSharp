<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ClashSharp.Components.StartupGuideDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel MinWidth="420" MaxWidth="640" Spacing="12">
        <Image Source="ms-appx:///Assets/Square150x150Logo.scale-200.png" Width="72" Height="72" Stretch="Uniform" HorizontalAlignment="Center" />
        <TextBlock x:Name="GuideDescriptionText" TextWrapping="WrapWholeWords" Style="{ThemeResource BodyTextBlockStyle}" />
        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ChecksPanel" Spacing="8" />
        </ScrollViewer>
    </StackPanel>
</ContentDialog>
