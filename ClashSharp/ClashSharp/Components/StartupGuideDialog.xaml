<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ClashSharp.Components.StartupGuideDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="520"
    MinWidth="0"
    MaxWidth="520">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">360</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">520</x:Double>
    </ContentDialog.Resources>

    <StackPanel MinWidth="360" MaxWidth="480" Spacing="12">
        <TextBlock x:Name="GuideDescriptionText" TextWrapping="WrapWholeWords" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ChecksPanel" Spacing="8" />
        </ScrollViewer>
    </StackPanel>
</ContentDialog>
